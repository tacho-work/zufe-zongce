{
  "name": "zongce-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore '*.db' src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "setup": "tsx src/setup.ts",
    "typecheck": "tsc --noEmit",
    "build:frontend": "cd ../frontend && npx vite build",
    "build:backend": "node scripts/esbuild-bundle.mjs",
    "build:release": "npm run build:frontend && npm run build:backend",
    "package:mac": "npx pkg dist-bundle/index.cjs -c package.json -t node20-macos-arm64 -o ../releases/zongce-macos",
    "package:win": "npx pkg dist-bundle/index.cjs -c package.json -t node20-win-x64 -o ../releases/zongce-win.exe",
    "package:linux": "npx pkg dist-bundle/index.cjs -c package.json -t node20-linux-x64 -o ../releases/zongce-linux",
    "package:all": "npm run package:mac && npm run package:win && npm run package:linux",
    "release": "npm run build:release && npm run package:all"
  },
  "pkg": {
    "assets": [
      "dist-bundle/public/**/*",
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "scripts": []
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "lucide-react": "^1.14.0",
    "multer": "^2.1.1",
    "pizzip": "^3.2.0",
    "sql.js": "^1.12.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/sql.js": "^1.4.11",
    "@types/supertest": "^7.2.0",
    "@yao-pkg/pkg": "^6.19.0",
    "esbuild": "^0.28.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6"
  }
}
